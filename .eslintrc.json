{
  "extends": ["next/core-web-vitals"],
  "ignorePatterns": ["node_modules/", ".next/", "dist/", "build/", "coverage/"],
  "overrides": [
    {
      "files": ["features/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": ["@/app/*"]
          }
        ]
      }
    },
    {
      "files": ["lib/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": ["@/app/*", "@/components/*"]
          }
        ]
      }
    },
    {
      "files": ["tests/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
