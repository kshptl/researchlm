    "test:visual:update": "playwright test tests/e2e/visual --update-snapshots",
    "validate:visual-coverage": "node scripts/validate-visual-coverage.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1000.0",
    "@aws-sdk/credential-providers": "^3.1000.0",
    "@xyflow/react": "^12.10.1",
    "next": "^16.1.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "1.51.1",
    "@testing-library/jest-dom": "6.4.8",
    "@testing-library/react": "16.0.1",
    "@types/node": "20.16.5",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.20",
    "eslint": "9.11.1",
    "eslint-config-next": "^16.1.6",
    "jsdom": "25.0.1",
    "postcss": "8.4.47",
    "prettier": "^3.8.1",
